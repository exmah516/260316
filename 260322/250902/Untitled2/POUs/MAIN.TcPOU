<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="MAIN" Id="{0f7d3262-e451-4dc7-838c-99daae61b3ae}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM MAIN
VAR
	init_		:		init;
	handle1_	:		handle;
	clear_err_	:		clear_err;
	err_		:		err;
	reset_		:		reset;
	self_check_ :       SelfCheck;
	i:INT;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[FOR i:=1 TO 7 DO
	G.axis[i]();	
END_FOR

IF TwinCAT_SystemInfoVarList._TaskInfo[1].FirstCycle THEN
	G.gen_state := _init;
	G.self_check_done := FALSE;
	G.handle_reinit_req := FALSE;
	G.handle_reinit_done := FALSE;
	G.estop_hold_req := TRUE;
	G.selfcheck_reset_req := TRUE;
	FOR i:=1 TO 7 DO
		G.SetPointGenEnable[i].Execute := FALSE;
		G.SetPointGenDisable[i].Execute := FALSE;
		G.axis_Reset[i].Execute := FALSE;
	END_FOR
END_IF
	
POWERED();
SETPOSITIONGEN();
RESETED();

CASE G.gen_state OF
	_init:			init_();
	_self_check:    self_check_();
	_handle:		handle1_();	
	_clear_err:		clear_err_();	
	_err:			err_();	
	_reset:			reset_();
END_CASE]]></ST>
    </Implementation>
