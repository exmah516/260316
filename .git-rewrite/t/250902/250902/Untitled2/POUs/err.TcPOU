<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="err" Id="{c264bb0b-28ae-4266-9c6d-88cfb4405e12}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK err
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
	i:INT;
	step:INT:=0;
	pulse_timer:TON;
	retry_timer:TON;
	has_err:BOOL;
	has_power_not_ready:BOOL;
	has_other_error:BOOL;
	all_powered:BOOL;
	power_not_ready_errid : UDINT := 16#00004650;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* 
Error recovery state:
  - disable external setpoint generation and keep estop hold active
  - if the only active power error is 16#00004650, recover by cycling MC_Power.Enable
  - other errors still use MC_Reset
  - leave _err only after errors are gone and all axes are powered again
*)

has_err := FALSE;
has_power_not_ready := FALSE;
has_other_error := FALSE;
all_powered := TRUE;

FOR i:=1 TO 7 DO
	IF NOT G.power_output[i].Done THEN
		all_powered := FALSE;
	END_IF

	IF G.axis[i].Status.Error OR G.power_output[i].Error OR G.reset_output[i].Error THEN
		has_err := TRUE;

		IF G.power_output[i].Error AND (G.power_output[i].ErrorID = power_not_ready_errid) THEN
			has_power_not_ready := TRUE;
		END_IF

		IF G.axis[i].Status.Error OR G.reset_output[i].Error OR (G.power_output[i].Error AND (G.power_output[i].ErrorID <> power_not_ready_errid)) THEN
			has_other_error := TRUE;
		END_IF
	END_IF
END_FOR

G.estop_hold_req := TRUE;

CASE step OF
0:
	FOR i:=1 TO 7 DO
		G.SetPointGenEnable[i].Execute := FALSE;
		G.SetPointGenDisable[i].Execute := TRUE;
		G.axis_Reset[i].Execute := FALSE;
	END_FOR
	pulse_timer(IN:=FALSE);
	retry_timer(IN:=FALSE);
	step := 1;

1:
	FOR i:=1 TO 7 DO
		G.SetPointGenDisable[i].Execute := FALSE;
	END_FOR

	IF (NOT has_err) AND all_powered THEN
		step := 0;
		G.gen_state := _clear_err;
		RETURN;
	END_IF

	IF NOT has_err THEN
		FOR i:=1 TO 7 DO
			G.axis_Reset[i].Execute := FALSE;
			G.power_[i].Enable := TRUE;
		END_FOR
		retry_timer(IN:=TRUE, PT:=T#2S);
		step := 11;
		RETURN;
	END_IF

	IF has_power_not_ready AND NOT has_other_error THEN
		pulse_timer(IN:=TRUE, PT:=T#200MS);
		retry_timer(IN:=FALSE);
		step := 10;
		RETURN;
	END_IF

	FOR i:=1 TO 7 DO
		IF G.axis[i].Status.Error OR G.power_output[i].Error OR G.reset_output[i].Error THEN
			G.axis_Reset[i].Execute := TRUE;
		END_IF
	END_FOR
	pulse_timer(IN:=TRUE, PT:=T#200MS);
	step := 2;

2:
	pulse_timer(IN:=TRUE);
	IF pulse_timer.Q THEN
		FOR i:=1 TO 7 DO
			G.axis_Reset[i].Execute := FALSE;
		END_FOR
		pulse_timer(IN:=FALSE);
		retry_timer(IN:=TRUE, PT:=T#2S);
		step := 3;
	END_IF

3:
	retry_timer(IN:=TRUE);

	IF (NOT has_err) AND all_powered THEN
		retry_timer(IN:=FALSE);
		step := 0;
		G.gen_state := _clear_err;
		RETURN;
	END_IF

	IF retry_timer.Q THEN
		retry_timer(IN:=FALSE);
		step := 1;
	END_IF

10:
	FOR i:=1 TO 7 DO
		G.axis_Reset[i].Execute := FALSE;
		IF G.power_output[i].Error AND (G.power_output[i].ErrorID = power_not_ready_errid) THEN
			G.power_[i].Enable := FALSE;
		ELSE
			G.power_[i].Enable := TRUE;
		END_IF
	END_FOR

	pulse_timer(IN:=TRUE, PT:=T#200MS);
	IF pulse_timer.Q THEN
		pulse_timer(IN:=FALSE);
		FOR i:=1 TO 7 DO
			G.power_[i].Enable := TRUE;
		END_FOR
		retry_timer(IN:=TRUE, PT:=T#3S);
		step := 11;
	END_IF

11:
	FOR i:=1 TO 7 DO
		G.power_[i].Enable := TRUE;
	END_FOR

	retry_timer(IN:=TRUE);

	IF (NOT has_err) AND all_powered THEN
		retry_timer(IN:=FALSE);
		step := 0;
		G.gen_state := _clear_err;
		RETURN;
	END_IF

	IF has_err THEN
		retry_timer(IN:=FALSE);
		step := 1;
		RETURN;
	END_IF

	IF retry_timer.Q THEN
		retry_timer(IN:=FALSE);
		step := 1;
	END_IF
END_CASE]]></ST>
    </Implementation>
    <LineIds Name="err">
      <LineId Id="64" Count="11" />
      <LineId Id="79" Count="2" />
      <LineId Id="9" Count="0" />
    </LineIds>
  </POU>
</TcPlcObject>
