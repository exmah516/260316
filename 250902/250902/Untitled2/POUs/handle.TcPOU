<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="handle" Id="{687f3d3e-09ee-464b-b8db-c97aea6d31ed}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK handle
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
	i,j,k:INT;
	v_step		: LREAL;
	avg_window	: INT;

	Kp			:	LREAL:=0.14;
	Ki			:	LREAL:=0.016;
	Kd			:	LREAL:=0.1;

	err, err_f, value_f,err_sum, v_limit, refer :	ARRAY[1..7] OF LREAL;
	v1			:	LREAL:=7.5;
	v2			:	LREAL:=1.5;
	act_hh		:	ARRAY[1..7] OF ARRAY [1..30] OF LREAL;
	pos_abs	:	LREAL;
	
	init_done : BOOL := FALSE;
	all_enabled : BOOL;
	all_powered : BOOL;
	has_axis_error : BOOL;
	hold_active : BOOL := FALSE;
	
	// software limit parameters
	right_slimit : ARRAY[1..7] OF LREAL;
	rslimit_distance	: ARRAY[1..7] OF LREAL := [30, 10, 10, 10, 10, 30, 15];
	left_slimit  : ARRAY[1..7] OF LREAL;
	left_from_right_distance : ARRAY[1..7] OF LREAL := [120.0, 0.0, 523.5, 0.0, 548.0, 534.0, 0.0];
	slimit_enable : ARRAY[1..7] OF BOOL := [TRUE, FALSE, TRUE, FALSE, TRUE, TRUE, FALSE];
END_VAR

]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF G.handle_reinit_req THEN
	init_done := FALSE;
	G.handle_reinit_done := FALSE;
	G.handle_reinit_req := FALSE;
	G.estop_hold_req := TRUE;
END_IF

IF NOT init_done THEN
	G.estop_hold_req := TRUE;
	all_enabled := TRUE;
	FOR i:=1 TO 7 DO
		G.SetPointGenEnable[i](Axis:=G.axis[i], Execute:=TRUE);
		IF NOT G.SetPointGenEnable[i].Done THEN
			all_enabled := FALSE;
		END_IF
	END_FOR
	
	IF all_enabled THEN
		// initialize buffered references from current actual position
		FOR j:=1 TO 7 DO
			G.Act_pos[j] := G.axis[j].NcToPlc.ActPos - G.init_pos[j];
			G.ref_slow[j] := G.Act_pos[j]; 
			G.act_h[j] := G.Act_pos[j]; 
			G.act_hf[j] := G.Act_pos[j];
			G.refer[j] := G.Act_pos[j];
			
			FOR k:=1 TO 30 DO
				act_hh[j][k] := G.Act_pos[j];
			END_FOR
			
			// initialize software limits:
			//   right_slimit: forbid further motion toward the right limit
			//   left_slimit : forbid further motion away from the right limit
			IF slimit_enable[j] THEN
				right_slimit[j] := G.rightlimit[j] - rslimit_distance[j];
				IF left_from_right_distance[j] > 0.0 THEN
					left_slimit[j] := G.rightlimit[j] - left_from_right_distance[j];
				ELSE
					left_slimit[j] := -1.0E30;
				END_IF
			END_IF
		END_FOR
		
		init_done := TRUE;
		G.handle_reinit_done := TRUE;
	END_IF
	RETURN; // wait until setpoint generator enable completes
END_IF

// smooth reference and apply velocity limiting
all_powered := TRUE;
FOR i:=1 TO 7 DO
	IF NOT G.power_output[i].Done THEN
		all_powered := FALSE;
		EXIT;
	END_IF
END_FOR

has_axis_error := FALSE;
FOR i:=1 TO 7 DO
	IF G.axis[i].Status.Error OR G.power_output[i].Error OR G.reset_output[i].Error THEN
		has_axis_error := TRUE;
		EXIT;
	END_IF
END_FOR

IF NOT all_powered THEN
	G.estop_hold_req := TRUE;
	hold_active := TRUE;
	FOR j:=1 TO 7 DO
		G.Act_pos[j] := G.axis[j].NcToPlc.ActPos - G.init_pos[j];
		G.refer[j] := G.Act_pos[j];
		G.ref_slow[j] := G.Act_pos[j];
		G.act_h[j] := G.Act_pos[j];
		G.act_hf[j] := G.Act_pos[j];
		FOR k:=1 TO 30 DO
			act_hh[j][k] := G.Act_pos[j];
		END_FOR
	END_FOR

	IF has_axis_error THEN
		G.gen_state := _err;
		RETURN;
	END_IF
	RETURN;
END_IF

IF hold_active THEN
	hold_active := FALSE;
	G.handle_reinit_done := FALSE;
	G.handle_reinit_req := TRUE;
	G.estop_hold_req := TRUE;
	IF has_axis_error THEN
		G.gen_state := _err;
	END_IF
	RETURN;
END_IF

IF has_axis_error THEN
	G.estop_hold_req := TRUE;
	G.gen_state := _err;
	RETURN;
END_IF

G.estop_hold_req := FALSE;

FOR j:=1 TO 7 DO
	G.Act_pos[j]:=G.axis[j].NcToPlc.ActPos-G.init_pos[j];

	v_step := G.v_limit[j];
	avg_window := 20;
	IF (j = 1) AND G.axis1_fast_return THEN
		v_step := 1000.0;
		avg_window := 1;
	ELSIF (j = 6) AND G.axis6_fast_retract THEN
		v_step := 1000.0;
		avg_window := 1;
	END_IF
	
	FOR k:=2 TO 20 DO
		act_hh[j][22-k]:=act_hh[j][21-k];
	END_FOR

	// clip illegal reference growth at software limits before rate limiting
	IF slimit_enable[j] THEN
		// at right limit: ignore further positive motion
		IF (G.axis[j].NcToPlc.ActPos >= right_slimit[j]) AND (G.refer[j] > G.ref_slow[j]) THEN
			G.refer[j] := G.ref_slow[j]; // hold position
		// at away limit: ignore further negative motion
		ELSIF (G.axis[j].NcToPlc.ActPos <= left_slimit[j]) AND (G.refer[j] < G.ref_slow[j]) THEN
			G.refer[j] := G.ref_slow[j]; // hold position
		END_IF
	END_IF

	IF (G.refer[j] - G.ref_slow[j]) > v_step THEN
		G.ref_slow[j] := G.ref_slow[j] + v_step;
	ELSIF (G.refer[j] - G.ref_slow[j]) < -v_step THEN
		G.ref_slow[j] := G.ref_slow[j] - v_step;
	ELSE
		G.ref_slow[j] := G.refer[j];
	END_IF

	act_hh[j][1]:=G.ref_slow[j];
	G.act_h[j]:=0;
	
	FOR i:=1 TO avg_window DO
		G.act_h[j]:=G.act_h[j]+act_hh[j][i]/TO_LREAL(avg_window);
	END_FOR
END_FOR

FOR i:=1 TO 7 DO
	// latch drive errors for reset logic
	IF G.power_output[i].Error THEN
		G.axis_Reset[i].Execute := TRUE;
		G.flag:=i;
		G.flagpos:=G.axis[i].NcToPlc.ActPos;
	END_IF
END_FOR

// feed smoothed positions to the external setpoint generator
FOR i:=1 TO 7 DO
	// convert relative smoothed position back to absolute axis coordinates
	pos_abs := G.act_h[i] + G.init_pos[i];

	MC_ExtSetPointGenFeed(
	Position:= pos_abs,
	Velocity:= 0,
	Acceleration:=0,
	Direction:= 1,
	Axis:= G.axis[i]);
	G.act_hf[i]:=G.act_h[i];
END_FOR

]]></ST>
    </Implementation>
    <LineIds Name="handle">
      <LineId Id="1616" Count="1" />
      <LineId Id="1596" Count="0" />
      <LineId Id="1636" Count="0" />
