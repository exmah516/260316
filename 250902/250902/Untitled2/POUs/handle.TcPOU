<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="handle" Id="{687f3d3e-09ee-464b-b8db-c97aea6d31ed}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK handle
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
	i,j,k:INT;
	v_step		: LREAL;
	avg_window	: INT;

	Kp			:	LREAL:=0.14;
	Ki			:	LREAL:=0.016;
	Kd			:	LREAL:=0.1;

	err, err_f, value_f,err_sum, v_limit, refer :	ARRAY[1..7] OF LREAL;
	v1			:	LREAL:=7.5;
	v2			:	LREAL:=1.5;
	act_hh		:	ARRAY[1..7] OF ARRAY [1..30] OF LREAL;
	pos_abs	:	LREAL;
	
	init_done : BOOL := FALSE;
	all_enabled : BOOL;
	all_powered : BOOL;
	hold_active : BOOL := FALSE;
	
	// 软限位参数
	right_slimit : ARRAY[1..7] OF LREAL;
	rslimit_distance	: ARRAY[1..7] OF LREAL := [30, 10, 10, 10, 10, 30, 15];
	left_slimit  : ARRAY[1..7] OF LREAL;
	slimit_enable : ARRAY[1..7] OF BOOL := [TRUE, FALSE, TRUE, FALSE, TRUE, TRUE, FALSE];
END_VAR

]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF G.handle_reinit_req THEN
	init_done := FALSE;
	G.handle_reinit_done := FALSE;
	G.handle_reinit_req := FALSE;
END_IF

IF NOT init_done THEN
	all_enabled := TRUE;
	FOR i:=1 TO 7 DO
		G.SetPointGenEnable[i](Axis:=G.axis[i], Execute:=TRUE);
		IF NOT G.SetPointGenEnable[i].Done THEN
			all_enabled := FALSE;
		END_IF
	END_FOR
	
	IF all_enabled THEN
		// 初始化位置平滑缓冲区，避免突变
		FOR j:=1 TO 7 DO
	
			G.ref_slow[j] := G.Act_pos[j]; 
			G.act_h[j] := G.Act_pos[j]; 
			G.refer[j] := G.Act_pos[j];
			
			FOR k:=1 TO 30 DO
				act_hh[j][k] := G.Act_pos[j];
			END_FOR
			
			// 初始化软限位值
			IF slimit_enable[j] THEN
				right_slimit[j] := G.rightlimit[j] - rslimit_distance[j];
				CASE j OF
				1: left_slimit[j] := right_slimit[j] - 90.0;
				3: left_slimit[j] := right_slimit[j] - 655.0;
				5: left_slimit[j] := right_slimit[j] - 670.0;
				6: left_slimit[j] := right_slimit[j] - 690.0;
				END_CASE
			END_IF
		END_FOR
		
		init_done := TRUE;
		G.handle_reinit_done := TRUE;
	END_IF
	RETURN; // 等待 Enable 完成后再开始 Feed
END_IF

// 平滑参考与速度门限（窗口平均 20 点）
all_powered := TRUE;
FOR i:=1 TO 7 DO
	IF NOT G.power_output[i].Done THEN
		all_powered := FALSE;
		EXIT;
	END_IF
END_FOR

IF NOT all_powered THEN
	G.estop_hold_req := TRUE;
	hold_active := TRUE;
	FOR j:=1 TO 7 DO
		G.Act_pos[j] := G.axis[j].NcToPlc.ActPos - G.init_pos[j];
		G.refer[j] := G.Act_pos[j];
		G.ref_slow[j] := G.Act_pos[j];
		G.act_h[j] := G.Act_pos[j];
		G.act_hf[j] := G.Act_pos[j];
		FOR k:=1 TO 30 DO
			act_hh[j][k] := G.Act_pos[j];
		END_FOR
	END_FOR
	RETURN;
END_IF

IF hold_active THEN
	hold_active := FALSE;
	G.estop_hold_req := FALSE;
	G.handle_reinit_done := FALSE;
	G.handle_reinit_req := TRUE;
END_IF

FOR j:=1 TO 7 DO
	
	G.Act_pos[j]:=G.axis[j].NcToPlc.ActPos-G.init_pos[j];

	v_step := G.v_limit[j];
	avg_window := 20;
	IF (j = 1) AND G.axis1_fast_return THEN
		v_step := 1000.0;
		avg_window := 1;
	ELSIF (j = 6) AND G.axis6_fast_retract THEN
		v_step := 1000.0;
		avg_window := 1;
	END_IF
	
	FOR k:=2 TO 20 DO
		act_hh[j][22-k]:=act_hh[j][21-k];
	END_FOR

	// 软限位保护：在应用速度限制前，先对 G.refer 进行限位裁剪
	// 这样可以屏蔽掉非法的方向增量，同时保留合法的方向
	IF slimit_enable[j] THEN
		// 当前位置 >= 右限位 且 试图继续向右(增大)
		IF (G.axis[j].NcToPlc.ActPos >= right_slimit[j]) AND (G.refer[j] > G.ref_slow[j]) THEN
			G.refer[j] := G.ref_slow[j]; // 保持不变，忽略增大
		// 当前位置 <= 左限位 且 试图继续向左(减小)
		ELSIF (G.axis[j].NcToPlc.ActPos <= left_slimit[j]) AND (G.refer[j] < G.ref_slow[j]) THEN
			G.refer[j] := G.ref_slow[j]; // 保持不变，忽略减小
		END_IF
	END_IF

	IF (G.refer[j] - G.ref_slow[j]) > v_step THEN
		G.ref_slow[j] := G.ref_slow[j] + v_step;
	ELSIF (G.refer[j] - G.ref_slow[j]) < -v_step THEN
		G.ref_slow[j] := G.ref_slow[j] - v_step;
	ELSE
		G.ref_slow[j] := G.refer[j];
	END_IF

	act_hh[j][1]:=G.ref_slow[j];

	G.act_h[j]:=0;
	
	FOR i:=1 TO avg_window DO
		G.act_h[j]:=G.act_h[j]+act_hh[j][i]/TO_LREAL(avg_window);
	END_FOR
END_FOR

FOR i:=1 TO 7 DO      
	// 检查驱动器错误并复位
	IF G.power_output[i].Error THEN
		G.axis_Reset[i].Execute := TRUE;
		G.flag:=i;
		G.flagpos:=G.axis[i].NcToPlc.ActPos;
	END_IF
END_FOR

//各关节跟随
FOR i:=1 TO 7 DO
	// 直接使用平滑后的参考位置，不叠加 PID 修正量
	// 注意：G.init_pos[i] 是相对零点的偏移量
	pos_abs := G.act_h[i] + G.init_pos[i];

	MC_ExtSetPointGenFeed(
	Position:= pos_abs,
	//Velocity:= 0, 
	Velocity:= 0, 
	Acceleration:=0,
	Direction:= 1,
	Axis:= G.axis[i]);
	G.act_hf[i]:=G.act_h[i];
END_FOR	



]]></ST>
    </Implementation>
    <LineIds Name="handle">
      <LineId Id="1616" Count="1" />
      <LineId Id="1596" Count="0" />
      <LineId Id="1636" Count="0" />
