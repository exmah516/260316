<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="handle" Id="{687f3d3e-09ee-464b-b8db-c97aea6d31ed}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK handle
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
	i,j,k:INT;
	v_step		: LREAL;
	avg_window	: INT;
	return_handoff_bypass : BOOL;
	avg_window_follow : INT := 20;
	avg_window_legacy : INT := 20;

	Kp			:	LREAL:=0.14;
	Ki			:	LREAL:=0.016;
	Kd			:	LREAL:=0.1;

	err, err_f, value_f,err_sum, v_limit, refer :	ARRAY[1..7] OF LREAL;
	v1			:	LREAL:=7.5;
	v2			:	LREAL:=1.5;
	act_hh		:	ARRAY[1..7] OF ARRAY [1..30] OF LREAL;
	pos_abs		:	LREAL;
	
	init_done : BOOL := FALSE;
	all_enabled : BOOL;
	all_powered : BOOL;
	has_axis_error : BOOL;
	hold_active : BOOL := FALSE;
	
	// software limit parameters
	right_slimit : ARRAY[1..7] OF LREAL;
	rslimit_distance	: ARRAY[1..7] OF LREAL := [99.0, 0.0, 666.0, 0.0, 688.0, 688.0, 0.0];
	slimit_enable : ARRAY[1..7] OF BOOL := [TRUE, FALSE, TRUE, FALSE, TRUE, TRUE, FALSE];

	ext_setpoint_enabled : ARRAY[1..7] OF BOOL := [FALSE,FALSE,FALSE,FALSE,FALSE,FALSE,FALSE];
	spg_enable_exec	: ARRAY[1..7] OF BOOL;
	spg_disable_exec : ARRAY[1..7] OF BOOL;

	return_state : ARRAY[1..7] OF INT;
	return_exec : ARRAY[1..7] OF BOOL;
	return_target_abs : ARRAY[1..7] OF LREAL;
	return_velocity : ARRAY[1..7] OF LREAL;
	return_acc : ARRAY[1..7] OF LREAL;
	return_dec : ARRAY[1..7] OF LREAL;
	return_jerk : ARRAY[1..7] OF LREAL;
	return_finish_error : ARRAY[1..7] OF BOOL;
	return_error_id_pending : ARRAY[1..7] OF UDINT;
	fb_return_move_abs : ARRAY[1..7] OF MC_MoveAbsolute;

	axis4_manual_state : INT := 0;
	axis4_request_dir_now : INT := 0;
	axis4_requested_dir : INT := 0;
	axis4_pending_dir : INT := 0;
	axis4_move_exec : BOOL := FALSE;
	axis4_stop_exec : BOOL := FALSE;
	axis4_finish_error : BOOL := FALSE;
	axis4_error_id_pending : UDINT := 0;
	axis4_manual_velocity : LREAL := 30;
	axis4_manual_acc : LREAL := 100;
	axis4_manual_dec : LREAL := 100;
	axis4_manual_jerk : LREAL := 500.0;
	axis4_manual_direction : MC_Direction := MC_Direction.MC_Positive_Direction;
	fb_axis4_move_velocity : MC_MoveVelocity;
	fb_axis4_stop : MC_Stop;
	ramp_counter: ARRAY[1..7] OF INT;
	act_h_prev : ARRAY[1..7] OF LREAL;
	vel_ff : LREAL;
	refer_prev      : ARRAY[1..7] OF LREAL;
	refer_interp    : ARRAY[1..7] OF LREAL;
	refer_step_from : ARRAY[1..7] OF LREAL;
	refer_step_to   : ARRAY[1..7] OF LREAL;
	refer_interval  : ARRAY[1..7] OF INT;
	refer_tick      : ARRAY[1..7] OF INT;
	refer_progress  : ARRAY[1..7] OF INT;
	// 2nd-order critically damped tracking filter (per-axis)
	traj_pos     : ARRAY[1..7] OF LREAL;  // filter output: smoothed position (relative coords, same frame as G.refer)
	traj_vel     : ARRAY[1..7] OF LREAL;  // filter output: velocity (mm/s or deg/s)
	traj_acc     : ARRAY[1..7] OF LREAL;  // filter output: acceleration (mm/s² or deg/s²)
	acc_raw      : LREAL;                  // scratch variable for unclipped acceleration

	// Filter tuning parameters
	traj_wn      : LREAL := 60.0;         // natural frequency (rad/s); shared across all filter-enabled axes
	traj_vmax    : ARRAY[1..7] OF LREAL := [80, 0, 80, 0, 80, 80, 0];   // velocity clamp (mm/s); 0 = unused axis
	traj_amax    : ARRAY[1..7] OF LREAL := [2000, 0, 2000, 0, 2000, 2000, 0]; // acceleration clamp (mm/s²)

	// Per-axis filter enable (TRUE = use traj filter output; FALSE = use legacy act_h path)
	traj_enable  : ARRAY[1..7] OF BOOL := [TRUE, FALSE, TRUE, FALSE, TRUE, TRUE, FALSE];
END_VAR

]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF G.handle_reinit_req THEN
	init_done := FALSE;
	G.handle_reinit_done := FALSE;
	G.handle_reinit_req := FALSE;
	G.estop_hold_req := TRUE;

	FOR i:=1 TO 7 DO
		ext_setpoint_enabled[i] := FALSE;
		spg_enable_exec[i] := FALSE;
		spg_disable_exec[i] := FALSE;
		return_state[i] := 0;
		return_exec[i] := FALSE;
		return_target_abs[i] := 0.0;
		return_velocity[i] := 0.0;
		return_acc[i] := 0.0;
		return_dec[i] := 0.0;
		return_jerk[i] := 0.0;
		return_finish_error[i] := FALSE;
		return_error_id_pending[i] := 0;
		refer_prev[i] := 0.0;
		refer_interp[i] := 0.0;
		refer_step_from[i] := 0.0;
		refer_step_to[i] := 0.0;
		refer_interval[i] := 50;
		refer_tick[i] := 0;
		refer_progress[i] := 50;
		traj_pos[i] := 0.0;
		traj_vel[i] := 0.0;
		traj_acc[i] := 0.0;
	END_FOR

	axis4_manual_state := 0;
	axis4_request_dir_now := 0;
	axis4_requested_dir := 0;
	axis4_pending_dir := 0;
	axis4_move_exec := FALSE;
	axis4_stop_exec := FALSE;
	axis4_finish_error := FALSE;
	axis4_error_id_pending := 0;

	G.axis1_return_cmd.Req := FALSE;
	G.axis1_return_cmd.Busy := FALSE;
	G.axis1_return_cmd.Done := FALSE;
	G.axis1_return_cmd.Error := FALSE;
	G.axis1_return_cmd.ErrorId := 0;
	G.axis3_return_cmd.Req := FALSE;
	G.axis3_return_cmd.Busy := FALSE;
	G.axis3_return_cmd.Done := FALSE;
	G.axis3_return_cmd.Error := FALSE;
	G.axis3_return_cmd.ErrorId := 0;
	G.axis5_return_cmd.Req := FALSE;
	G.axis5_return_cmd.Busy := FALSE;
	G.axis5_return_cmd.Done := FALSE;
	G.axis5_return_cmd.Error := FALSE;
	G.axis5_return_cmd.ErrorId := 0;
	G.axis6_return_cmd.Req := FALSE;
	G.axis6_return_cmd.Busy := FALSE;
	G.axis6_return_cmd.Done := FALSE;
	G.axis6_return_cmd.Error := FALSE;
	G.axis6_return_cmd.ErrorId := 0;

	G.axis4_fwd_req := FALSE;
	G.axis4_rev_req := FALSE;
	G.axis4_manual_busy := FALSE;
	G.axis4_manual_done := FALSE;
	G.axis4_manual_error := FALSE;
	G.axis4_manual_error_id := 0;
END_IF

IF NOT init_done THEN
	G.estop_hold_req := TRUE;
	all_enabled := TRUE;
	FOR i:=1 TO 7 DO
		G.SetPointGenEnable[i](Axis:=G.axis[i], Execute:=TRUE);
		IF NOT G.SetPointGenEnable[i].Done THEN
			all_enabled := FALSE;
		END_IF
	END_FOR
	
	IF all_enabled THEN
		FOR j:=1 TO 7 DO
			G.Act_pos[j] := G.axis[j].NcToPlc.ActPos - G.init_pos[j];
			G.act_pos_from_left[j] := G.axis[j].NcToPlc.ActPos - G.leftlimit[j];
			G.ref_slow[j] := G.Act_pos[j];
			G.act_h[j] := G.Act_pos[j];
			G.act_hf[j] := G.Act_pos[j];
			G.refer[j] := G.Act_pos[j];
			G.refer_from_left[j] := G.act_pos_from_left[j];
			ext_setpoint_enabled[j] := TRUE;
			
			FOR k:=1 TO 30 DO
				act_hh[j][k] := G.Act_pos[j];
			END_FOR
			act_h_prev[j] := G.Act_pos[j];
			refer_prev[j] := G.Act_pos[j];
			refer_interp[j] := G.Act_pos[j];
			refer_step_from[j] := G.Act_pos[j];
			refer_step_to[j] := G.Act_pos[j];
			refer_interval[j] := 50;
			refer_tick[j] := 0;
			refer_progress[j] := 50;
			traj_pos[j] := G.Act_pos[j];
			traj_vel[j] := 0.0;
			traj_acc[j] := 0.0;
			IF slimit_enable[j] THEN
				right_slimit[j] := G.leftlimit[j] + rslimit_distance[j];
			END_IF
		END_FOR

		G.axis1_return_cmd.Busy := FALSE;
		G.axis1_return_cmd.Done := FALSE;
		G.axis1_return_cmd.Error := FALSE;
		G.axis1_return_cmd.ErrorId := 0;
		G.axis3_return_cmd.Busy := FALSE;
		G.axis3_return_cmd.Done := FALSE;
		G.axis3_return_cmd.Error := FALSE;
		G.axis3_return_cmd.ErrorId := 0;
		G.axis5_return_cmd.Busy := FALSE;
		G.axis5_return_cmd.Done := FALSE;
		G.axis5_return_cmd.Error := FALSE;
		G.axis5_return_cmd.ErrorId := 0;
		G.axis6_return_cmd.Busy := FALSE;
		G.axis6_return_cmd.Done := FALSE;
		G.axis6_return_cmd.Error := FALSE;
		G.axis6_return_cmd.ErrorId := 0;
		G.axis4_manual_busy := FALSE;
		G.axis4_manual_done := FALSE;
		G.axis4_manual_error := FALSE;
		G.axis4_manual_error_id := 0;
		
		init_done := TRUE;
		G.handle_reinit_done := TRUE;
	END_IF
	RETURN;
END_IF

all_powered := TRUE;
FOR i:=1 TO 7 DO
	IF NOT G.power_output[i].Done THEN
		all_powered := FALSE;
		EXIT;
	END_IF
END_FOR

has_axis_error := FALSE;
FOR i:=1 TO 7 DO
	IF G.axis[i].Status.Error OR G.power_output[i].Error OR G.reset_output[i].Error THEN
		has_axis_error := TRUE;
		EXIT;
	END_IF
END_FOR

IF NOT all_powered THEN
	G.estop_hold_req := TRUE;
	hold_active := TRUE;
	FOR j:=1 TO 7 DO
		G.Act_pos[j] := G.axis[j].NcToPlc.ActPos - G.init_pos[j];
		G.act_pos_from_left[j] := G.axis[j].NcToPlc.ActPos - G.leftlimit[j];
		G.refer[j] := G.Act_pos[j];
		G.ref_slow[j] := G.Act_pos[j];
		G.act_h[j] := G.Act_pos[j];
		G.act_hf[j] := G.Act_pos[j];
		G.refer_from_left[j] := G.act_pos_from_left[j];
		FOR k:=1 TO 30 DO
			act_hh[j][k] := G.Act_pos[j];
			refer_prev[j] := G.Act_pos[j];
			refer_interp[j] := G.Act_pos[j];
			refer_step_from[j] := G.Act_pos[j];
			refer_step_to[j] := G.Act_pos[j];
			refer_progress[j] := refer_interval[j];
			act_h_prev[j] := G.Act_pos[j];
			traj_pos[j] := G.Act_pos[j];
			traj_vel[j] := 0.0;
			traj_acc[j] := 0.0;
		END_FOR
	END_FOR

	IF has_axis_error THEN
		G.gen_state := _err;
		RETURN;
	END_IF
	RETURN;
END_IF

IF hold_active THEN
	hold_active := FALSE;
	G.handle_reinit_done := FALSE;
	G.handle_reinit_req := TRUE;
	G.estop_hold_req := TRUE;
	IF has_axis_error THEN
		G.gen_state := _err;
	END_IF
	RETURN;
END_IF

IF has_axis_error THEN
	G.estop_hold_req := TRUE;
	G.gen_state := _err;
	RETURN;
END_IF

G.estop_hold_req := FALSE;
// 电缸5统一由上位机按键请求驱动，避免现场对 WORD 直写链路的不可控覆盖。
IF G.cylinder5_press_req THEN
	G.cylinder5_value := 0;
ELSE
	G.cylinder5_value := 2000;
END_IF

FOR i:=1 TO 7 DO
	spg_enable_exec[i] := FALSE;
	spg_disable_exec[i] := FALSE;
	return_exec[i] := FALSE;
	return_target_abs[i] := 0.0;
	return_velocity[i] := 0.0;
	return_acc[i] := 0.0;
	return_dec[i] := 0.0;
	return_jerk[i] := 0.0;
END_FOR
axis4_move_exec := FALSE;
axis4_stop_exec := FALSE;

FOR j:=1 TO 7 DO
	G.Act_pos[j] := G.axis[j].NcToPlc.ActPos - G.init_pos[j];
	G.act_pos_from_left[j] := G.axis[j].NcToPlc.ActPos - G.leftlimit[j];
	G.refer_from_left[j] := (G.refer[j] + G.init_pos[j]) - G.leftlimit[j];

	v_step := G.v_limit[j];
	// 回退接管旁路：除上位机快退标志外，叠加 PLC 回退 Busy 状态兜底，
	// 避免个别周期标志抖动导致回退末端重新进入慢斜坡/均值链路。
	return_handoff_bypass := ((j = 1) AND (G.axis1_fast_return OR G.axis1_return_cmd.Busy))
		OR ((j = 6) AND (G.axis6_fast_retract OR G.axis6_return_cmd.Busy));
	IF return_handoff_bypass THEN
		avg_window := 1;
		ramp_counter[j] := 0;
	ELSIF G.startup_smoothing_bypass THEN
		ramp_counter[j] := MIN(ramp_counter[j] + 1, avg_window_legacy);
		avg_window := MAX(1, ramp_counter[j]);
	ELSE
		ramp_counter[j] := MIN(ramp_counter[j] + 1, avg_window_follow);
		avg_window := MAX(1, ramp_counter[j]);
	END_IF
	
	FOR k:=2 TO 20 DO
		act_hh[j][22-k] := act_hh[j][21-k];
	END_FOR

	IF slimit_enable[j] THEN
		IF (G.axis[j].NcToPlc.ActPos >= right_slimit[j]) AND (G.refer[j] > G.ref_slow[j]) THEN
			G.refer[j] := G.ref_slow[j];
		END_IF
	END_IF

	IF return_handoff_bypass THEN
		G.ref_slow[j] := G.refer[j];
	ELSIF G.startup_smoothing_bypass THEN
		IF (G.refer[j] - G.ref_slow[j]) > v_step THEN
			G.ref_slow[j] := G.ref_slow[j] + v_step;
		ELSIF (G.refer[j] - G.ref_slow[j]) < -v_step THEN
			G.ref_slow[j] := G.ref_slow[j] - v_step;
		ELSE
			G.ref_slow[j] := G.refer[j];
		END_IF
	ELSE
		// EMA disabled in follow path: keep legacy v_step ramp behavior.
		IF (G.refer[j] - G.ref_slow[j]) > v_step THEN
			G.ref_slow[j] := G.ref_slow[j] + v_step;
		ELSIF (G.refer[j] - G.ref_slow[j]) < -v_step THEN
			G.ref_slow[j] := G.ref_slow[j] - v_step;
		ELSE
			G.ref_slow[j] := G.refer[j];
		END_IF
	END_IF

	IF return_handoff_bypass THEN
		FOR i:=1 TO 20 DO
			act_hh[j][i] := G.ref_slow[j];
		END_FOR
		G.act_h[j] := G.ref_slow[j];
	ELSE
		act_hh[j][1] := G.ref_slow[j];
		G.act_h[j] := 0;

		FOR i:=1 TO avg_window DO
			G.act_h[j] := G.act_h[j] + act_hh[j][i] / TO_LREAL(avg_window);
		END_FOR
	END_IF

	// ===== 2nd-order critically damped tracking filter =====
	// Input: G.refer[j] (raw target from C++)
	// Output: traj_pos[j], traj_vel[j], traj_acc[j] (smooth trajectory)
	// Only active for traj_enable axes in normal follow mode.
	// Bypass/startup/non-filter axes snap to act_h with zero vel/acc.
	IF traj_enable[j] AND NOT return_handoff_bypass AND NOT G.startup_smoothing_bypass THEN
		// Critically damped 2nd-order: acc = wn² * (target - pos) - 2*wn * vel
		acc_raw := traj_wn * traj_wn * (G.refer[j] - traj_pos[j]) - 2.0 * traj_wn * traj_vel[j];

		// Clamp acceleration to traj_amax
		IF acc_raw > traj_amax[j] THEN
			acc_raw := traj_amax[j];
		ELSIF acc_raw < -traj_amax[j] THEN
			acc_raw := -traj_amax[j];
		END_IF

		// Forward-Euler integration: acc -> vel (dt = 0.001s = 1ms PLC cycle)
		traj_acc[j] := acc_raw;
		traj_vel[j] := traj_vel[j] + 0.001 * traj_acc[j];

		// Clamp velocity to traj_vmax
		IF traj_vel[j] > traj_vmax[j] THEN
			traj_vel[j] := traj_vmax[j];
		ELSIF traj_vel[j] < -traj_vmax[j] THEN
			traj_vel[j] := -traj_vmax[j];
		END_IF

		// Forward-Euler integration: vel -> pos (dt = 0.001s)
		traj_pos[j] := traj_pos[j] + 0.001 * traj_vel[j];

		// Deadband: suppress micro-oscillation when effectively stationary
		IF ABS(G.refer[j] - traj_pos[j]) < 0.001 AND ABS(traj_vel[j]) < 0.01 THEN
			traj_pos[j] := G.refer[j];
			traj_vel[j] := 0.0;
			traj_acc[j] := 0.0;
		END_IF
	ELSE
		// Non-filter axis, bypass, or startup: snap filter state to current act_h
		traj_pos[j] := G.act_h[j];
		traj_vel[j] := 0.0;
		traj_acc[j] := 0.0;
	END_IF
	// ===== end tracking filter =====
END_FOR

IF return_state[1] = 0 THEN
	G.axis1_return_cmd.Busy := FALSE;
	IF NOT G.axis1_return_cmd.Req THEN
		G.axis1_return_cmd.Done := FALSE;
		G.axis1_return_cmd.Error := FALSE;
		G.axis1_return_cmd.ErrorId := 0;
		return_finish_error[1] := FALSE;
		return_error_id_pending[1] := 0;
		refer_prev[1] := 0.0;
		refer_interp[1] := 0.0;
		refer_step_from[1] := 0.0;
		refer_step_to[1] := 0.0;
		refer_interval[1] := 50;
		refer_tick[1] := 0;
		refer_progress[1] := 50;
	ELSIF (NOT G.axis1_return_cmd.Done) AND (NOT G.axis1_return_cmd.Error) THEN
		return_state[1] := 10;
	END_IF
END_IF

CASE return_state[1] OF
10:
	G.axis1_return_cmd.Busy := TRUE;
	spg_disable_exec[1] := TRUE;
	IF G.SetPointGenDisable[1].Done OR NOT G.SetPointGenDisable[1].Enabled THEN
		ext_setpoint_enabled[1] := FALSE;
		return_state[1] := 20;
	END_IF

20:
	G.axis1_return_cmd.Busy := TRUE;
	return_exec[1] := TRUE;
	return_target_abs[1] := G.axis1_return_cmd.TargetAbs;
	return_velocity[1] := G.axis1_return_cmd.Velocity;
	return_acc[1] := G.axis1_return_cmd.Acc;
	return_dec[1] := G.axis1_return_cmd.Dec;
	return_jerk[1] := G.axis1_return_cmd.Jerk;
	G.refer_from_left[1] := return_target_abs[1] - G.leftlimit[1];

	IF fb_return_move_abs[1].Done OR
	   ((NOT fb_return_move_abs[1].Busy) AND (ABS(G.axis[1].NcToPlc.ActPos - return_target_abs[1]) <= 0.05)) THEN
		return_finish_error[1] := FALSE;
		return_error_id_pending[1] := 0;
		return_state[1] := 30;
	ELSIF fb_return_move_abs[1].Error OR fb_return_move_abs[1].CommandAborted THEN
		return_finish_error[1] := TRUE;
		return_error_id_pending[1] := fb_return_move_abs[1].ErrorID;
		return_state[1] := 30;
	END_IF

30:
    G.axis1_return_cmd.Busy := TRUE;

    IF ABS(G.axis[1].NcToPlc.ActVelo) > 0.5 THEN
        // 还没停稳，保持当前参考不变，等下一个周期
        // 不做 snap，不做 spg_enable，什么都不动
    ELSE
        // 真正停稳了，执行原有逻辑
        G.Act_pos[1] := G.axis[1].NcToPlc.ActPos - G.init_pos[1];
        G.act_pos_from_left[1] := G.axis[1].NcToPlc.ActPos - G.leftlimit[1];
        G.refer[1] := G.Act_pos[1];
        G.ref_slow[1] := G.Act_pos[1];
        G.act_h[1] := G.Act_pos[1];
        G.act_hf[1] := G.Act_pos[1];
        G.refer_from_left[1] := G.act_pos_from_left[1];
        FOR k:=1 TO 30 DO
            act_hh[1][k] := G.Act_pos[1];
        END_FOR
		refer_prev[1] := G.Act_pos[1];
		refer_interp[1] := G.Act_pos[1];
		refer_step_from[1] := G.Act_pos[1];
		refer_step_to[1] := G.Act_pos[1];
		refer_progress[1] := refer_interval[1];
		act_h_prev[1] := G.Act_pos[1];
		traj_pos[1] := G.Act_pos[1];
		traj_vel[1] := 0.0;
		traj_acc[1] := 0.0;
        spg_enable_exec[1] := TRUE;
        IF G.SetPointGenEnable[1].Done THEN
            ext_setpoint_enabled[1] := TRUE;
            G.axis1_return_cmd.Busy := FALSE;
            IF return_finish_error[1] THEN
                G.axis1_return_cmd.Done := FALSE;
                G.axis1_return_cmd.Error := TRUE;
                G.axis1_return_cmd.ErrorId := return_error_id_pending[1];
            ELSE
                G.axis1_return_cmd.Done := TRUE;
                G.axis1_return_cmd.Error := FALSE;
                G.axis1_return_cmd.ErrorId := 0;
            END_IF
            return_finish_error[1] := FALSE;
            return_error_id_pending[1] := 0;
            return_state[1] := 0;
        END_IF
    END_IF
END_CASE

IF return_state[3] = 0 THEN
	G.axis3_return_cmd.Busy := FALSE;
	IF NOT G.axis3_return_cmd.Req THEN
		G.axis3_return_cmd.Done := FALSE;
		G.axis3_return_cmd.Error := FALSE;
		G.axis3_return_cmd.ErrorId := 0;
		return_finish_error[3] := FALSE;
		return_error_id_pending[3] := 0;
		refer_prev[3] := 0.0;
		refer_interp[3] := 0.0;
		refer_step_from[3] := 0.0;
		refer_step_to[3] := 0.0;
		refer_interval[3] := 50;
		refer_tick[3] := 0;
		refer_progress[3] := 50;
	ELSIF (NOT G.axis3_return_cmd.Done) AND (NOT G.axis3_return_cmd.Error) THEN
		return_state[3] := 10;
	END_IF
END_IF

CASE return_state[3] OF
10:
	G.axis3_return_cmd.Busy := TRUE;
	spg_disable_exec[3] := TRUE;
	IF G.SetPointGenDisable[3].Done OR NOT G.SetPointGenDisable[3].Enabled THEN
		ext_setpoint_enabled[3] := FALSE;
		return_state[3] := 20;
	END_IF

20:
	G.axis3_return_cmd.Busy := TRUE;
	return_exec[3] := TRUE;
	return_target_abs[3] := G.axis3_return_cmd.TargetAbs;
	return_velocity[3] := G.axis3_return_cmd.Velocity;
	return_acc[3] := G.axis3_return_cmd.Acc;
	return_dec[3] := G.axis3_return_cmd.Dec;
	return_jerk[3] := G.axis3_return_cmd.Jerk;
	G.refer_from_left[3] := return_target_abs[3] - G.leftlimit[3];

	IF fb_return_move_abs[3].Done OR
	   ((NOT fb_return_move_abs[3].Busy) AND (ABS(G.axis[3].NcToPlc.ActPos - return_target_abs[3]) <= 0.05)) THEN
		return_finish_error[3] := FALSE;
		return_error_id_pending[3] := 0;
		return_state[3] := 30;
	ELSIF fb_return_move_abs[3].Error OR fb_return_move_abs[3].CommandAborted THEN
		return_finish_error[3] := TRUE;
		return_error_id_pending[3] := fb_return_move_abs[3].ErrorID;
		return_state[3] := 30;
	END_IF

30:
    G.axis3_return_cmd.Busy := TRUE;

    IF ABS(G.axis[3].NcToPlc.ActVelo) > 0.5 THEN
        // 还没停稳，保持当前参考不变，等下一个周期
        // 不做 snap，不做 spg_enable，什么都不动
    ELSE
        // 真正停稳了，执行原有逻辑
        G.Act_pos[3] := G.axis[3].NcToPlc.ActPos - G.init_pos[3];
        G.act_pos_from_left[3] := G.axis[3].NcToPlc.ActPos - G.leftlimit[3];
        G.refer[3] := G.Act_pos[3];
        G.ref_slow[3] := G.Act_pos[3];
        G.act_h[3] := G.Act_pos[3];
        G.act_hf[3] := G.Act_pos[3];
        G.refer_from_left[3] := G.act_pos_from_left[3];
        FOR k:=1 TO 30 DO
            act_hh[3][k] := G.Act_pos[3];
        END_FOR
		refer_prev[3] := G.Act_pos[3];
		refer_interp[3] := G.Act_pos[3];
		refer_step_from[3] := G.Act_pos[3];
		refer_step_to[3] := G.Act_pos[3];
		refer_progress[3] := refer_interval[3];
		act_h_prev[3] := G.Act_pos[3];
		traj_pos[3] := G.Act_pos[3];
		traj_vel[3] := 0.0;
		traj_acc[3] := 0.0;
        spg_enable_exec[3] := TRUE;
        IF G.SetPointGenEnable[3].Done THEN
            ext_setpoint_enabled[3] := TRUE;
            G.axis3_return_cmd.Busy := FALSE;
            IF return_finish_error[3] THEN
                G.axis3_return_cmd.Done := FALSE;
                G.axis3_return_cmd.Error := TRUE;
                G.axis3_return_cmd.ErrorId := return_error_id_pending[3];
            ELSE
                G.axis3_return_cmd.Done := TRUE;
                G.axis3_return_cmd.Error := FALSE;
                G.axis3_return_cmd.ErrorId := 0;
            END_IF
            return_finish_error[3] := FALSE;
            return_error_id_pending[3] := 0;
            return_state[3] := 0;
        END_IF
    END_IF
END_CASE

IF return_state[5] = 0 THEN
	G.axis5_return_cmd.Busy := FALSE;
	IF NOT G.axis5_return_cmd.Req THEN
		G.axis5_return_cmd.Done := FALSE;
		G.axis5_return_cmd.Error := FALSE;
		G.axis5_return_cmd.ErrorId := 0;
		return_finish_error[5] := FALSE;
		return_error_id_pending[5] := 0;
		refer_prev[5] := 0.0;
		refer_interp[5] := 0.0;
		refer_step_from[5] := 0.0;
		refer_step_to[5] := 0.0;
		refer_interval[5] := 50;
		refer_tick[5] := 0;
		refer_progress[5] := 50;
	ELSIF (NOT G.axis5_return_cmd.Done) AND (NOT G.axis5_return_cmd.Error) THEN
		return_state[5] := 10;
	END_IF
END_IF

CASE return_state[5] OF
10:
	G.axis5_return_cmd.Busy := TRUE;
	spg_disable_exec[5] := TRUE;
	IF G.SetPointGenDisable[5].Done OR NOT G.SetPointGenDisable[5].Enabled THEN
		ext_setpoint_enabled[5] := FALSE;
		return_state[5] := 20;
	END_IF

20:
	G.axis5_return_cmd.Busy := TRUE;
	return_exec[5] := TRUE;
	return_target_abs[5] := G.axis5_return_cmd.TargetAbs;
	return_velocity[5] := G.axis5_return_cmd.Velocity;
	return_acc[5] := G.axis5_return_cmd.Acc;
	return_dec[5] := G.axis5_return_cmd.Dec;
	return_jerk[5] := G.axis5_return_cmd.Jerk;
	G.refer_from_left[5] := return_target_abs[5] - G.leftlimit[5];

	IF fb_return_move_abs[5].Done OR
	   ((NOT fb_return_move_abs[5].Busy) AND (ABS(G.axis[5].NcToPlc.ActPos - return_target_abs[5]) <= 0.05)) THEN
		return_finish_error[5] := FALSE;
		return_error_id_pending[5] := 0;
		return_state[5] := 30;
	ELSIF fb_return_move_abs[5].Error OR fb_return_move_abs[5].CommandAborted THEN
		return_finish_error[5] := TRUE;
		return_error_id_pending[5] := fb_return_move_abs[5].ErrorID;
		return_state[5] := 30;
	END_IF

30:
    G.axis5_return_cmd.Busy := TRUE;

    IF ABS(G.axis[5].NcToPlc.ActVelo) > 0.5 THEN
        // 还没停稳，保持当前参考不变，等下一个周期
        // 不做 snap，不做 spg_enable，什么都不动
    ELSE
        // 真正停稳了，执行原有逻辑
        G.Act_pos[5] := G.axis[5].NcToPlc.ActPos - G.init_pos[5];
        G.act_pos_from_left[5] := G.axis[5].NcToPlc.ActPos - G.leftlimit[5];
        G.refer[5] := G.Act_pos[5];
        G.ref_slow[5] := G.Act_pos[5];
        G.act_h[5] := G.Act_pos[5];
        G.act_hf[5] := G.Act_pos[5];
        G.refer_from_left[5] := G.act_pos_from_left[5];
        FOR k:=1 TO 30 DO
            act_hh[5][k] := G.Act_pos[5];
        END_FOR
		refer_prev[5] := G.Act_pos[5];
		refer_interp[5] := G.Act_pos[5];
		refer_step_from[5] := G.Act_pos[5];
		refer_step_to[5] := G.Act_pos[5];
		refer_progress[5] := refer_interval[5];
		act_h_prev[5] := G.Act_pos[5];
		traj_pos[5] := G.Act_pos[5];
		traj_vel[5] := 0.0;
		traj_acc[5] := 0.0;
        spg_enable_exec[5] := TRUE;
        IF G.SetPointGenEnable[5].Done THEN
            ext_setpoint_enabled[5] := TRUE;
            G.axis5_return_cmd.Busy := FALSE;
            IF return_finish_error[5] THEN
                G.axis5_return_cmd.Done := FALSE;
                G.axis5_return_cmd.Error := TRUE;
                G.axis5_return_cmd.ErrorId := return_error_id_pending[5];
            ELSE
                G.axis5_return_cmd.Done := TRUE;
                G.axis5_return_cmd.Error := FALSE;
                G.axis5_return_cmd.ErrorId := 0;
            END_IF
            return_finish_error[5] := FALSE;
            return_error_id_pending[5] := 0;
            return_state[5] := 0;
        END_IF
    END_IF
END_CASE

IF return_state[6] = 0 THEN
	G.axis6_return_cmd.Busy := FALSE;
	IF NOT G.axis6_return_cmd.Req THEN
		G.axis6_return_cmd.Done := FALSE;
		G.axis6_return_cmd.Error := FALSE;
		G.axis6_return_cmd.ErrorId := 0;
		return_finish_error[6] := FALSE;
		return_error_id_pending[6] := 0;
		refer_prev[6] := 0.0;
		refer_interp[6] := 0.0;
		refer_step_from[6] := 0.0;
		refer_step_to[6] := 0.0;
		refer_interval[6] := 50;
		refer_tick[6] := 0;
		refer_progress[6] := 50;
	ELSIF (NOT G.axis6_return_cmd.Done) AND (NOT G.axis6_return_cmd.Error) THEN
		return_state[6] := 10;
	END_IF
END_IF

CASE return_state[6] OF
10:
	G.axis6_return_cmd.Busy := TRUE;
	spg_disable_exec[6] := TRUE;
	IF G.SetPointGenDisable[6].Done OR NOT G.SetPointGenDisable[6].Enabled THEN
		ext_setpoint_enabled[6] := FALSE;
		return_state[6] := 20;
	END_IF

20:
	G.axis6_return_cmd.Busy := TRUE;
	return_exec[6] := TRUE;
	return_target_abs[6] := G.axis6_return_cmd.TargetAbs;
	return_velocity[6] := G.axis6_return_cmd.Velocity;
	return_acc[6] := G.axis6_return_cmd.Acc;
	return_dec[6] := G.axis6_return_cmd.Dec;
	return_jerk[6] := G.axis6_return_cmd.Jerk;
	G.refer_from_left[6] := return_target_abs[6] - G.leftlimit[6];

	IF fb_return_move_abs[6].Done OR
	   ((NOT fb_return_move_abs[6].Busy) AND (ABS(G.axis[6].NcToPlc.ActPos - return_target_abs[6]) <= 0.05)) THEN
		return_finish_error[6] := FALSE;
		return_error_id_pending[6] := 0;
		return_state[6] := 30;
	ELSIF fb_return_move_abs[6].Error OR fb_return_move_abs[6].CommandAborted THEN
		return_finish_error[6] := TRUE;
		return_error_id_pending[6] := fb_return_move_abs[6].ErrorID;
		return_state[6] := 30;
	END_IF

30:
    G.axis6_return_cmd.Busy := TRUE;

    IF ABS(G.axis[6].NcToPlc.ActVelo) > 0.5 THEN
        // 还没停稳，保持当前参考不变，等下一个周期
        // 不做 snap，不做 spg_enable，什么都不动
    ELSE
        // 真正停稳了，执行原有逻辑
        G.Act_pos[6] := G.axis[6].NcToPlc.ActPos - G.init_pos[6];
        G.act_pos_from_left[6] := G.axis[6].NcToPlc.ActPos - G.leftlimit[6];
        G.refer[6] := G.Act_pos[6];
        G.ref_slow[6] := G.Act_pos[6];
        G.act_h[6] := G.Act_pos[6];
        G.act_hf[6] := G.Act_pos[6];
        G.refer_from_left[6] := G.act_pos_from_left[6];
        FOR k:=1 TO 30 DO
            act_hh[6][k] := G.Act_pos[6];
        END_FOR
		refer_prev[6] := G.Act_pos[6];
		refer_interp[6] := G.Act_pos[6];
		refer_step_from[6] := G.Act_pos[6];
		refer_step_to[6] := G.Act_pos[6];
		refer_progress[6] := refer_interval[6];
		act_h_prev[6] := G.Act_pos[6];
		traj_pos[6] := G.Act_pos[6];
		traj_vel[6] := 0.0;
		traj_acc[6] := 0.0;
        spg_enable_exec[6] := TRUE;
        IF G.SetPointGenEnable[6].Done THEN
            ext_setpoint_enabled[6] := TRUE;
            G.axis6_return_cmd.Busy := FALSE;
            IF return_finish_error[6] THEN
                G.axis6_return_cmd.Done := FALSE;
                G.axis6_return_cmd.Error := TRUE;
                G.axis6_return_cmd.ErrorId := return_error_id_pending[6];
            ELSE
                G.axis6_return_cmd.Done := TRUE;
                G.axis6_return_cmd.Error := FALSE;
                G.axis6_return_cmd.ErrorId := 0;
            END_IF
            return_finish_error[6] := FALSE;
            return_error_id_pending[6] := 0;
            return_state[6] := 0;
        END_IF
    END_IF
END_CASE

axis4_request_dir_now := 0;
IF G.axis4_fwd_req AND NOT G.axis4_rev_req THEN
	axis4_request_dir_now := 1;
ELSIF G.axis4_rev_req AND NOT G.axis4_fwd_req THEN
	axis4_request_dir_now := -1;
END_IF

IF axis4_manual_state = 0 THEN
	G.axis4_manual_busy := FALSE;
	IF axis4_request_dir_now = 0 THEN
		G.axis4_manual_done := FALSE;
		G.axis4_manual_error := FALSE;
		G.axis4_manual_error_id := 0;
	ELSIF NOT G.axis4_manual_error THEN
		G.axis4_manual_done := FALSE;
		G.axis4_manual_error := FALSE;
		G.axis4_manual_error_id := 0;
		axis4_requested_dir := axis4_request_dir_now;
		axis4_pending_dir := 0;
		axis4_finish_error := FALSE;
		axis4_error_id_pending := 0;
		axis4_manual_state := 10;
	END_IF
END_IF

CASE axis4_manual_state OF
10:
	G.axis4_manual_busy := TRUE;
	spg_disable_exec[4] := TRUE;
	IF G.SetPointGenDisable[4].Done OR NOT G.SetPointGenDisable[4].Enabled THEN
		ext_setpoint_enabled[4] := FALSE;
		axis4_manual_state := 20;
	END_IF

20:
	G.axis4_manual_busy := TRUE;
	axis4_pending_dir := axis4_request_dir_now;
	IF axis4_requested_dir >= 0 THEN
		axis4_manual_direction := MC_Direction.MC_Positive_Direction;
	ELSE
		axis4_manual_direction := MC_Direction.MC_Negative_Direction;
	END_IF

	IF axis4_pending_dir = 0 THEN
		axis4_manual_state := 30;
	ELSIF axis4_pending_dir <> axis4_requested_dir THEN
		axis4_manual_state := 30;
	ELSE
		axis4_move_exec := TRUE;
	END_IF

	IF fb_axis4_move_velocity.Error OR fb_axis4_move_velocity.CommandAborted THEN
		axis4_finish_error := TRUE;
		axis4_error_id_pending := fb_axis4_move_velocity.ErrorID;
		G.axis4_manual_error_id := fb_axis4_move_velocity.ErrorID;
		axis4_pending_dir := 0;
		axis4_manual_state := 40;
	END_IF

30:
	G.axis4_manual_busy := TRUE;
	axis4_pending_dir := axis4_request_dir_now;
	axis4_stop_exec := TRUE;

	IF fb_axis4_stop.Error THEN
		axis4_finish_error := TRUE;
		axis4_error_id_pending := fb_axis4_stop.ErrorID;
		axis4_pending_dir := 0;
		axis4_manual_state := 39;
	ELSIF fb_axis4_stop.Done OR (ABS(G.axis[4].NcToPlc.ActVelo) <= 0.05) THEN
		IF axis4_pending_dir <> 0 THEN
			axis4_requested_dir := axis4_pending_dir;
			axis4_manual_state := 20;
		ELSE
			axis4_requested_dir := 0;
			axis4_manual_state := 39;
		END_IF
	END_IF

39:
G.axis4_manual_busy := TRUE;
// One-cycle gap: let MC_Stop FB release the axis (Execute goes FALSE at top of loop)
// Next cycle, state 40 will give SetPointGenEnable a clean rising edge
axis4_manual_state := 40;
	
40:
	G.axis4_manual_busy := TRUE;
	G.Act_pos[4] := G.axis[4].NcToPlc.ActPos - G.init_pos[4];
	G.act_pos_from_left[4] := G.axis[4].NcToPlc.ActPos - G.leftlimit[4];
	G.refer[4] := G.Act_pos[4];
	G.ref_slow[4] := G.Act_pos[4];
	G.act_h[4] := G.Act_pos[4];
	G.act_hf[4] := G.Act_pos[4];
	G.refer_from_left[4] := G.act_pos_from_left[4];
	FOR k:=1 TO 30 DO
		act_hh[4][k] := G.Act_pos[4];
	END_FOR
	refer_prev[4] := G.Act_pos[4];
	refer_interp[4] := G.Act_pos[4];
	refer_step_from[4] := G.Act_pos[4];
	refer_step_to[4] := G.Act_pos[4];
	refer_progress[4] := refer_interval[4];
	act_h_prev[4] := G.Act_pos[4];
	traj_pos[4] := G.Act_pos[4];
	traj_vel[4] := 0.0;
	traj_acc[4] := 0.0;
	spg_enable_exec[4] := TRUE;
	IF G.SetPointGenEnable[4].Done THEN
		ext_setpoint_enabled[4] := TRUE;
		G.axis4_manual_busy := FALSE;
		IF axis4_finish_error THEN
			G.axis4_manual_done := FALSE;
			G.axis4_manual_error := TRUE;
			G.axis4_manual_error_id := axis4_error_id_pending;
		ELSE
			G.axis4_manual_done := TRUE;
			G.axis4_manual_error := FALSE;
			G.axis4_manual_error_id := 0;
		END_IF
		axis4_finish_error := FALSE;
		axis4_error_id_pending := 0;
		axis4_manual_state := 0;
	END_IF
END_CASE

FOR i:=1 TO 7 DO
	IF G.power_output[i].Error THEN
		G.axis_Reset[i].Execute := TRUE;
		G.flag := i;
		G.flagpos := G.axis[i].NcToPlc.ActPos;
	END_IF
END_FOR

FOR i:=1 TO 7 DO
	IF ext_setpoint_enabled[i] THEN
		IF traj_enable[i] AND NOT G.startup_smoothing_bypass THEN
			// Filtered path: feed smooth pos + vel + acc to NC
			pos_abs := traj_pos[i] + G.init_pos[i];
			MC_ExtSetPointGenFeed(
				Position     := pos_abs,
				Velocity     := traj_vel[i],
				Acceleration := traj_acc[i],
				Direction    := 1,
				Axis         := G.axis[i]);
		ELSE
			// Legacy path: axes 2/4/7 or startup bypass
			pos_abs := G.act_h[i] + G.init_pos[i];
			MC_ExtSetPointGenFeed(
				Position     := pos_abs,
				Velocity     := 0,
				Acceleration := 0,
				Direction    := 1,
				Axis         := G.axis[i]);
		END_IF
		G.act_hf[i] := G.act_h[i];
	ELSE
		G.act_hf[i] := G.axis[i].NcToPlc.ActPos - G.init_pos[i];
	END_IF
END_FOR

FOR i:=1 TO 7 DO
	G.SetPointGenEnable[i](Axis:=G.axis[i], Execute:=spg_enable_exec[i]);
	G.SetPointGenDisable[i](Axis:=G.axis[i], Execute:=spg_disable_exec[i]);
	fb_return_move_abs[i](
		Axis:=G.axis[i],
		Position:=return_target_abs[i],
		Velocity:=return_velocity[i],
		Acceleration:=return_acc[i],
		Deceleration:=return_dec[i],
		Jerk:=return_jerk[i],
		Execute:=return_exec[i]
	);
END_FOR

fb_axis4_move_velocity(
	Axis:=G.axis[4],
	Execute:=axis4_move_exec,
	Velocity:=axis4_manual_velocity,
	Acceleration:=axis4_manual_acc,
	Deceleration:=axis4_manual_dec,
	Jerk:=axis4_manual_jerk,
	Direction:=axis4_manual_direction
);
fb_axis4_stop(
	Axis:=G.axis[4],
	Execute:=axis4_stop_exec,
	Deceleration:=axis4_manual_dec,
	Jerk:=axis4_manual_jerk
);

]]></ST>
