<Window x:Class="AdsControlUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AdsControlUI"
        Title="ADS 控制可视化" Height="700" Width="780"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <local:BoolToColorConverter x:Key="BoolToGreenRed" TrueColor="LimeGreen" FalseColor="Gray"/>
        <local:BoolToColorConverter x:Key="BoolToYellowGray" TrueColor="Gold" FalseColor="Gray"/>
        <local:BoolToColorConverter x:Key="BoolToRedGray" TrueColor="Red" FalseColor="Gray"/>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 状态栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Ellipse Width="12" Height="12" Margin="0,0,4,0"
                     Fill="{Binding IsConnected, Converter={StaticResource BoolToGreenRed}}"/>
            <TextBlock Text="连接" Margin="0,0,12,0"/>
            <Ellipse Width="12" Height="12" Margin="0,0,4,0"
                     Fill="{Binding ControlActive, Converter={StaticResource BoolToGreenRed}}"/>
            <TextBlock Text="控制" Margin="0,0,12,0"/>
            <Ellipse Width="12" Height="12" Margin="0,0,4,0"
                     Fill="{Binding FreezeActive, Converter={StaticResource BoolToYellowGray}}"/>
            <TextBlock Text="暂停" Margin="0,0,12,0"/>
            <Ellipse Width="12" Height="12" Margin="0,0,4,0"
                     Fill="{Binding EstopHold, Converter={StaticResource BoolToRedGray}}"/>
            <TextBlock Text="急停" Margin="0,0,12,0"/>
            <TextBlock Text="{Binding ModeText, StringFormat='模式: {0}'}" FontWeight="Bold" Margin="12,0,0,0"/>
            <TextBlock Text="{Binding PhaseText}" Foreground="DarkBlue" Margin="12,0,0,0"/>
        </StackPanel>

        <!-- 主内容 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：轴位置 -->
            <GroupBox Grid.Column="0" Header="轴位置 (mm)" Margin="0,0,6,0">
                <StackPanel Margin="4">
                    <TextBlock Text="{Binding Axis1Pos, StringFormat='轴1 (导管推送): {0:F2}'}" Margin="0,2"/>
                    <ProgressBar Value="{Binding Axis1Pos, Mode=OneWay}" Minimum="-100" Maximum="100" Height="14" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Axis2Pos, StringFormat='轴2 (导管旋转): {0:F2}'}" Margin="0,2"/>
                    <ProgressBar Value="{Binding Axis2Pos, Mode=OneWay}" Minimum="-20" Maximum="20" Height="14" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Axis3Pos, StringFormat='轴3 (递送): {0:F2}'}" Margin="0,2"/>
                    <ProgressBar Value="{Binding Axis3Pos, Mode=OneWay}" Minimum="-100" Maximum="700" Height="14" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Axis4Pos, StringFormat='轴4 (点动): {0:F2}'}" Margin="0,2"/>
                    <ProgressBar Value="{Binding Axis4Pos, Mode=OneWay}" Minimum="-50" Maximum="50" Height="14" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Axis5Pos, StringFormat='轴5 (镜像): {0:F2}'}" Margin="0,2"/>
                    <ProgressBar Value="{Binding Axis5Pos, Mode=OneWay}" Minimum="-100" Maximum="700" Height="14" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Axis6Pos, StringFormat='轴6 (导丝推送): {0:F2}'}" Margin="0,2"/>
                    <ProgressBar Value="{Binding Axis6Pos, Mode=OneWay}" Minimum="-100" Maximum="700" Height="14" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Axis7Pos, StringFormat='轴7 (导丝旋转): {0:F2}'}" Margin="0,2"/>
                    <ProgressBar Value="{Binding Axis7Pos, Mode=OneWay}" Minimum="-20" Maximum="20" Height="14" Margin="0,0,0,4"/>
                </StackPanel>
            </GroupBox>

            <!-- 右侧：控制 -->
            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                <!-- 电缸控制 -->
                <GroupBox Header="电缸控制">
                    <UniformGrid Columns="2" Margin="4">
                        <ToggleButton Content="电缸1" IsChecked="{Binding Cyl1Open, Mode=OneWay}"
                                      Click="Cyl1_Click" Margin="2"/>
                        <ToggleButton Content="电缸2" IsChecked="{Binding Cyl2Open, Mode=OneWay}"
                                      Click="Cyl2_Click" Margin="2"/>
                        <ToggleButton Content="电缸3" IsChecked="{Binding Cyl3Open, Mode=OneWay}"
                                      Click="Cyl3_Click" Margin="2"/>
                        <ToggleButton Content="电缸4" IsChecked="{Binding Cyl4Open, Mode=OneWay}"
                                      Click="Cyl4_Click" Margin="2"/>
                    </UniformGrid>
                </GroupBox>

                <!-- 模式切换 (4模式) -->
                <GroupBox Header="模式切换" Margin="0,8,0,0">
                    <UniformGrid Columns="2" Margin="4">
                        <RadioButton Content="导管递送" GroupName="Mode" Click="ModeCathFwd_Click" IsChecked="True" Margin="2"/>
                        <RadioButton Content="导管撤出" GroupName="Mode" Click="ModeCathRev_Click" Margin="2"/>
                        <RadioButton Content="导丝递送" GroupName="Mode" Click="ModeGuideFwd_Click" Margin="2"/>
                        <RadioButton Content="导丝撤出" GroupName="Mode" Click="ModeGuideRev_Click" Margin="2"/>
                    </UniformGrid>
                </GroupBox>

                <!-- 力反馈 -->
                <GroupBox Header="力反馈" Margin="0,8,0,0">
                    <StackPanel Margin="4">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="零点采集" Click="Zero_Click" Margin="0,0,8,0" Padding="8,2"/>
                            <Button Content="力反馈开关" Click="FfToggle_Click" Margin="0,0,8,0" Padding="8,2"/>
                            <ToggleButton Content="数据记录" IsChecked="{Binding ForceLogRunning, Mode=OneWay}"
                                          Click="ForceLog_Click" Padding="8,2"/>
                        </StackPanel>
                        <TextBlock Margin="0,4,0,0" Text="{Binding Force582F, StringFormat='F = {0:F3} N'}"/>
                        <TextBlock Text="{Binding Force582N, StringFormat='T = {0:F5} N·m'}"/>
                        <TextBlock Text="{Binding CalZeroed, StringFormat='已标零: {0}'}" Margin="0,2,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- 启动准备 -->
                <GroupBox Header="启动准备" Margin="0,8,0,0">
                    <StackPanel Margin="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/>
                                <RowDefinition/><RowDefinition/><RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="轴1 (5-95mm):" VerticalAlignment="Center" Margin="0,1"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TbAxis1" Text="20" Margin="4,1"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="轴3 (10-650mm):" VerticalAlignment="Center" Margin="0,1"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TbAxis3" Text="635" Margin="4,1"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="轴5 (10-670mm):" VerticalAlignment="Center" Margin="0,1"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="TbAxis5" Text="290" Margin="4,1"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="轴6 (10-670mm):" VerticalAlignment="Center" Margin="0,1"/>
                            <TextBox Grid.Row="3" Grid.Column="1" x:Name="TbAxis6" Text="310" Margin="4,1"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="轴2 (-360~360°):" VerticalAlignment="Center" Margin="0,1"/>
                            <TextBox Grid.Row="4" Grid.Column="1" x:Name="TbAxis2" Text="0" Margin="4,1"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="轴7 (-360~360°):" VerticalAlignment="Center" Margin="0,1"/>
                            <TextBox Grid.Row="5" Grid.Column="1" x:Name="TbAxis7" Text="0" Margin="4,1"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="速度比例:" VerticalAlignment="Center" Margin="0,1"/>
                            <TextBox Grid.Row="6" Grid.Column="1" x:Name="TbSpeed" Text="0.005" Margin="4,1"/>
                        </Grid>
                        <TextBlock x:Name="StartupError" Foreground="Red" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Content="执行启动准备 (S)" Click="ExecuteStartup_Click" Padding="8,4" Margin="0,0,8,0"/>
                            <Button Content="直接控制 (C)" Click="DirectControl_Click" Padding="8,4"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
